# Upstox API credentials (required)
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# Market data stream settings
UPSTOX_STREAM_MODE=full
UPSTOX_AUTO_RECONNECT=true
UPSTOX_RECONNECT_INTERVAL=5
UPSTOX_MAX_RETRIES=10

# Storage
ODYSSEY_OUTPUT_DIR=data
ODYSSEY_CSV_ENABLED=false

# PostgreSQL / TimescaleDB (NIFTY streamer)
ODYSSEY_DB_ENABLED=true
ODYSSEY_DATABASE_URL=postgresql://odyssey:odyssey@localhost:5432/odyssey
ODYSSEY_ATM_ROLL_ENABLED=true

# Logging
ODYSSEY_LOG_LEVEL=INFO
ODYSSEY_LOG_FILE=logs/odyssey_trade.log

# --- Phase 1 Trading Engine ---
# paper = simulated fills at LTP; live = real Upstox orders
ODYSSEY_TRADING_MODE=paper
ODYSSEY_ALGO_NAME=odyssey-nifty-v1
ODYSSEY_UNDERLYING=NIFTY
ODYSSEY_NIFTY_INDEX_KEY=NSE_INDEX|Nifty 50
ODYSSEY_OPTION_EXPIRY=current_week
ODYSSEY_STRATEGY=nifty_momentum
ODYSSEY_PRODUCT=I
ODYSSEY_POLL_INTERVAL_SEC=30
ODYSSEY_MAX_OPEN_POSITIONS=2
ODYSSEY_MAX_DAILY_LOSS_INR=5000
ODYSSEY_MAX_ORDER_LOTS=1
ODYSSEY_MOMENTUM_THRESHOLD_POINTS=50
ODYSSEY_JOURNAL_ENABLED=true
ODYSSEY_KILL_SWITCH=false
