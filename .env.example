# Upstox API credentials (required)
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# Market data stream settings
UPSTOX_STREAM_MODE=full
UPSTOX_AUTO_RECONNECT=true
UPSTOX_RECONNECT_INTERVAL=5
UPSTOX_MAX_RETRIES=10

# Storage
ODYSSEY_OUTPUT_DIR=data
ODYSSEY_CSV_ENABLED=true

# Logging
ODYSSEY_LOG_LEVEL=INFO
ODYSSEY_LOG_FILE=logs/upstox_streamer.log
